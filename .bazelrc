common --enable_bzlmod

# default settings
build --incompatible_disallow_empty_glob
build --keep_going
build --verbose_failures
build --disk_cache=~/.cache/bazel-disk
test --test_output=errors
run --color=yes

# quick alias
build:linux_arm64 --platforms=@io_bazel_rules_go//go/toolchain:linux_arm64_cgo
build:windows_arm64 --platforms=@io_bazel_rules_go//go/toolchain:windows_arm64_cgo

# hermetic toolchain
common --@rules_python//python/config_settings:bootstrap_impl=script
common --enable_platform_specific_config
build  --worker_sandboxing
build  --experimental_output_directory_naming_scheme=diff_against_dynamic_baseline

# windows
startup --windows_enable_symlinks
build --enable_runfiles

# build info inject
common --define=VERSION=v0.0.0-dev.0
