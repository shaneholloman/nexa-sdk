load("@io_bazel_rules_go//go:def.bzl", "go_library")

# Generated protobuf Go stubs for the qaihm proto package.
#
# These files are checked in and should NOT be edited by hand.
# To regenerate after updating .proto files in cli/proto/:
#
#   cd cli && buf generate
#
# Then commit the updated *.pb.go files.

